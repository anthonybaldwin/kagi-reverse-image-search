{
  "manifest_version": 3,
  "name": "Kagi Reverse Image Search",
  "version": "1.1",
  "description": "Select an area on a webpage and search it using Kagi Reverse Image Search",
  "permissions": ["storage", "activeTab", "scripting", "tabs", "notifications"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Select area for Kagi Image Search (Ctrl+Shift+K)"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    },
    {
      "matches": ["*://*.kagi.com/*"],
      "js": ["kagi-theme-detector.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "search.html",
        "search.js",
        "search-theme.js",
        "upload.html",
        "upload.js",
        "icons/*.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Activate selection mode"
    }
  }
}
